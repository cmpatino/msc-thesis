\@writefile{toc}{\contentsline {section}{\numberline {5.4}Using Privileged Context for Teacher-Assisted Distillation}{24}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5.5}Extending from top-1 to top-$K$ Log Probabilities}{24}{}\protected@file@percent }
\newlabel{sec: exps_top_k}{{5.5}{24}{}{section.5.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.8}{\ignorespaces Effect of increasing the top-$K$ log probabilities. The 0.6B student benefits from increasing $K$ for the smallest teacher, but its performance degrades when using more log probabilities from the 235B teacher. These results suggest that the 0.6B student cannot capture the increasing complexity of the large teacher but benefits from more detailed feedback from a teacher within its reach. For the 4B student, scaling $K$ does not have a positive impact since its performance remains constant or decreases for all teachers.}}{25}{}\protected@file@percent }
\newlabel{fig: top-k_effect}{{5.8}{25}{}{figure.5.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.3}{\ignorespaces Probability mass coverage for different top-$K$ values and student-teacher combinations. The 4B/4B setting was not evaluated.}}{25}{}\protected@file@percent }
