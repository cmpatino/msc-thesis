\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces Comparison between providing the targeted intervention as privileged context or through a system prompt. The key difference is that the privileged context is only seen by the teacher while the system prompt is seen by the teacher and the student.}}{21}{}\protected@file@percent }
\newlabel{fig: pc_vs_system_prompt_example}{{5.4}{21}{}{figure.5.4}{}}
